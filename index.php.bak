<?php

/**
 * Laravel Public Folder Redirect
 * This file redirects all requests to the public folder
 */

// Get the request URI
$uri = urldecode(
    parse_url($_SERVER['REQUEST_URI'], PHP_URL_PATH) ?? ''
);

// Remove the base path if needed
$basePath = '/garage';
if (strpos($uri, $basePath) === 0) {
    $uri = substr($uri, strlen($basePath));
}

// Redirect to public folder
if ($uri === '' || $uri === '/') {
    header('Location: /garage/public/');
} else {
    header('Location: /garage/public' . $uri);
}
exit;
